---
// Layout base de Caleta Suites Tenerife.
// Replica la estructura del sitio WordPress actual sin rediseño.
// Incluye: GTM (placeholder vía import.meta.env), JSON-LD LodgingBusiness,
// meta OG/Twitter, canonical, lang dinámico EN/ES.
import { siteConfig } from '../utils/siteConfig';
import { lodgingBusiness } from '@caletasuites/seo';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  /**
   * Título visible de la página (<title>). Usa el seoTitle de Yoast si existe;
   * si no, se compone arriba a partir del title genérico + la marca.
   */
  title: string;
  /** Meta description de la página. Fallback al genérico solo si falta. */
  description?: string;
  /** Idioma de la página: 'en' (raíz) | 'es' (/es/). */
  lang?: 'en' | 'es';
  /** Imagen para Open Graph / Twitter (ruta absoluta o relativa al sitio). */
  ogImage?: string;
  /**
   * Pathname de la traducción del otro idioma (hreflang). Si falta, la página solo
   * declara su alternate self + x-default.
   */
  altPath?: string;
  /** Bloques JSON-LD adicionales por página (Apartment, BlogPosting, BreadcrumbList…). */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description = siteConfig.description,
  lang = 'en',
  ogImage = siteConfig.defaultOgImage,
  altPath,
  jsonLd: jsonLdExtra = [],
} = Astro.props;

// GTM ID desde el .env de la app (placeholder GTM-XXXXXX en .env.example).
const gtmId = import.meta.env.PUBLIC_GTM_ID;

// Canonical: URL absoluta self-referencial de la página actual (con trailing slash,
// regla inmutable). Astro.url.pathname ya respeta trailingSlash 'always'.
const canonical = new URL(Astro.url.pathname, siteConfig.url).href;
const ogImageUrl = new URL(ogImage, siteConfig.url).href;

// --- hreflang ----------------------------------------------------------------
// Cada página declara su propio alternate (self) y, si tiene par de traducción,
// el del otro idioma. x-default apunta SIEMPRE al inglés:
//   - si esta página es EN → x-default = self (canonical).
//   - si esta página es ES → x-default = su par EN (altPath), si lo hay.
const urlAlt = altPath ? new URL(altPath, siteConfig.url).href : null;

// Construye la lista de alternates (idioma → URL) sin duplicar.
const alternates: { hreflang: string; href: string }[] = [
  { hreflang: lang, href: canonical },
];
if (urlAlt) {
  alternates.push({ hreflang: lang === 'es' ? 'en' : 'es', href: urlAlt });
}
// x-default = la URL EN del par. Si esta página es EN, es la propia; si es ES, es altPath.
const xDefault = lang === 'en' ? canonical : urlAlt;

// --- JSON-LD -----------------------------------------------------------------
// LodgingBusiness site-wide (todas las páginas) + bloques específicos por página.
const lodging = lodgingBusiness({
  nombre: siteConfig.name,
  descripcion: siteConfig.description,
  url: siteConfig.url,
  imagen: new URL(siteConfig.logo, siteConfig.url).href,
  direccion: {
    addressLocality: siteConfig.location.locality,
    addressRegion: siteConfig.location.region,
    addressCountry: siteConfig.location.country,
  },
  telephone: siteConfig.contact.telephone,
  email: siteConfig.contact.email,
  geo: { latitude: siteConfig.location.latitude, longitude: siteConfig.location.longitude },
  knowsLanguage: siteConfig.knowsLanguage,
  aggregateRating: siteConfig.aggregateRating,
  sameAs: siteConfig.sameAs as unknown as string[],
});
const bloquesJsonLd = [lodging, ...jsonLdExtra];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* hreflang: self + par de traducción (si existe) + x-default = inglés. */}
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_GB'} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* JSON-LD: LodgingBusiness site-wide + bloques específicos de cada página. */}
    {bloquesJsonLd.map((bloque) => (
      <script type="application/ld+json" set:html={JSON.stringify(bloque)} is:inline />
    ))}

    {/*
      Hojas de estilo del tema WordPress (archub + kit Elementor), servidas desde
      /wp-assets/css/. ORDEN DE CARGA (la cascada importa para fidelidad visual):
        1. Fuentes web (definen @font-face que el resto referencia).
        2. Iconos (FontAwesome + Elementor icons): glyphs usados por header/footer.
        3. Tema base (archub-style) y tipografía del tema.
        4. Child theme (archub-child-style): overrides del tema base.
        5. Base Elementor (elementor-custom-frontend) y utilidades (bootstrap, lqd).
        6. Widgets Elementor concretos (heading, image, divider, social-icons).
        7. theme-elementor.css: CSS compilado por página de Elementor (último, gana
           sobre los anteriores por especificidad/orden — replica el sitio en vivo).
    */}
    {/* 1. Fuentes */}
    <link rel="stylesheet" href="/wp-assets/css/font-bevietnampro.css" />
    <link rel="stylesheet" href="/wp-assets/css/font-dmserifdisplay.css" />
    <link rel="stylesheet" href="/wp-assets/css/font-librebaskerville.css" />
    <link rel="stylesheet" href="/wp-assets/css/font-montserrat.css" />
    <link rel="stylesheet" href="/wp-assets/css/font-sourceserif4.css" />
    {/* 2. Iconos */}
    <link rel="stylesheet" href="/wp-assets/css/fontawesome.css" />
    <link rel="stylesheet" href="/wp-assets/css/fontawesome-brands.css" />
    <link rel="stylesheet" href="/wp-assets/css/elementor-icons.css" />
    {/* 3. Tema base + tipografía del tema */}
    <link rel="stylesheet" href="/wp-assets/css/archub-style.css" />
    <link rel="stylesheet" href="/wp-assets/css/archub-typography.css" />
    {/* 4. Child theme (overrides del tema base) */}
    <link rel="stylesheet" href="/wp-assets/css/archub-child-style.css" />
    {/* 5. Base Elementor + utilidades */}
    <link rel="stylesheet" href="/wp-assets/css/elementor-custom-frontend.css" />
    <link rel="stylesheet" href="/wp-assets/css/bootstrap-optimize.css" />
    <link rel="stylesheet" href="/wp-assets/css/lqd-essentials.css" />
    {/* 6. Widgets Elementor */}
    <link rel="stylesheet" href="/wp-assets/css/elementor-widget-heading.css" />
    <link rel="stylesheet" href="/wp-assets/css/elementor-widget-image.css" />
    <link rel="stylesheet" href="/wp-assets/css/elementor-widget-divider.css" />
    <link rel="stylesheet" href="/wp-assets/css/elementor-widget-social-icons.css" />
    {/* 7. CSS compilado por página de Elementor (último por cascada). */}
    <link rel="stylesheet" href="/wp-assets/css/theme-elementor.css" />

    {/* Google Tag Manager (placeholder vía import.meta.env.PUBLIC_GTM_ID) */}
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        {`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',gtmId);`}
      </script>
    )}
  </head>
  <body>
    {/* GTM noscript (placeholder vía import.meta.env.PUBLIC_GTM_ID) */}
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"></iframe>
      </noscript>
    )}

    <Header lang={lang} />
    <main id="contenido-principal">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
