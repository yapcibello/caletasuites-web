---
// Navbar de Caleta Suites — esqueleto AAA.
// Estructura de navegación provisional: el menú real se replicará del sitio
// WordPress actual en la fase de migración (mismas etiquetas y URLs).
// Accesibilidad: <nav> con aria-label, enlaces con foco visible (gestionado en
// global.css con :focus-visible).
interface Props {
  /** Idioma activo: 'en' (raíz) | 'es' (/es/). */
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

// Prefijo de idioma: EN sin prefijo (raíz), ES bajo /es/.
const base = lang === 'es' ? '/es/' : '/';
const etiquetas =
  lang === 'es'
    ? { inicio: 'Inicio', apartamentos: 'Apartamentos', contacto: 'Contacto' }
    : { inicio: 'Home', apartamentos: 'Apartments', contacto: 'Contact' };
---

<nav aria-label={lang === 'es' ? 'Navegación principal' : 'Main navigation'}>
  <ul>
    {/* TODO F-Migra: replicar el menú real del tema WordPress (etiquetas y URLs 1:1). */}
    <li><a href={base}>{etiquetas.inicio}</a></li>
    <li><a href={`${base}apartments/`}>{etiquetas.apartamentos}</a></li>
    <li><a href={`${base}contact/`}>{etiquetas.contacto}</a></li>
  </ul>
</nav>
