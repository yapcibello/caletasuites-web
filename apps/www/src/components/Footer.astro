---
// Footer global de Caleta Suites — chrome real extraído del tema WordPress (archub + Elementor).
//
// El markup completo (columnas, enlaces legales, redes sociales, copyright) vive en
// _chrome/footer-{en,es}.html y se inyecta con set:html. Se importa el HTML crudo
// vía import.meta.glob(?raw, eager) — mismo patrón que Header.astro y el contenido.
//
// REGLA INNEGOCIABLE: las URLs de los enlaces del pie son inmutables. Solo se
// normalizan, de forma defensiva, posibles URLs absolutas de assets a /wp-content/...
import { fixUrlsChrome } from '../utils/chrome';

interface Props {
  /** Idioma activo: 'en' (raíz) | 'es' (/es/). */
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

// HTML crudo del chrome (eager para build estático).
const footersRaw = import.meta.glob('./_chrome/footer-*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const claveFooter = lang === 'es' ? 'footer-es' : 'footer-en';
const entradaFooter = Object.entries(footersRaw).find(([ruta]) => ruta.includes(claveFooter));
if (!entradaFooter) {
  throw new Error(`No se encontró el chrome del footer para idioma="${lang}" (${claveFooter}).`);
}

// Normaliza URLs absolutas de assets a rutas locales (defensivo).
const htmlFooter = fixUrlsChrome(entradaFooter[1]);
---

{/* Chrome real del footer (incluye su propio <footer> landmark con role WPFooter). */}
<Fragment set:html={htmlFooter} />
