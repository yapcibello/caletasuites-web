---
// Footer global de Caleta Suites — chrome real extraído del tema WordPress (archub + Elementor).
//
// El markup completo (columnas, enlaces legales, redes sociales, copyright) vive en
// _chrome/footer-{en,es}.html y se inyecta con set:html. Se importa el HTML crudo
// vía import.meta.glob(?raw, eager) — mismo patrón que Header.astro y el contenido.
//
// REGLA INNEGOCIABLE: las URLs de los enlaces del pie son inmutables. Solo se
// normalizan, de forma defensiva, posibles URLs absolutas de assets a /wp-content/...
import { fixUrlsChrome } from '../utils/chrome';

interface Props {
  /** Idioma activo: 'en' (raíz) | 'es' (/es/). */
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

// HTML crudo del chrome (eager para build estático).
const footersRaw = import.meta.glob('./_chrome/footer-*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const claveFooter = lang === 'es' ? 'footer-es' : 'footer-en';
const entradaFooter = Object.entries(footersRaw).find(([ruta]) => ruta.includes(claveFooter));
if (!entradaFooter) {
  throw new Error(`No se encontró el chrome del footer para idioma="${lang}" (${claveFooter}).`);
}

// Normaliza URLs absolutas de assets a rutas locales (defensivo).
let htmlFooter = fixUrlsChrome(entradaFooter[1]);

// --- Enlace a la declaración de accesibilidad (additivo, sin alterar el diseño) ---
// La zona de enlaces legales del footer ya es una lista <ul> homogénea (Aviso Legal,
// Privacidad, Condiciones, Cookies). Inyectamos un <li> adicional con EXACTAMENTE las
// mismas clases que el resto de ítems legales, justo después del enlace de cookies,
// para que el aspecto visual sea idéntico (réplica intacta) y la declaración quede
// enlazada desde todas las páginas (requisito W3C WAI / RD 1112/2018). URLs nuevas con
// trailing slash: ES → /accesibilidad/ · EN → /en/accessibility/.
const urlAccesibilidad = lang === 'es' ? '/accesibilidad/' : '/en/accessibility/';
const etiquetaAccesibilidad = lang === 'es' ? 'Accesibilidad' : 'Accessibility';
const itemAccesibilidad = `
							<li>
								<a  href="${urlAccesibilidad}" >

																		<span class="link-icon d-inline-flex hide-if-empty align-items-center left-icon icon-next-to-label"></span>

																		${etiquetaAccesibilidad}
																								</a>
														</li>
`;
// El enlace de cookies es el último de la lista legal en ambos idiomas: insertamos
// el nuevo <li> tras su cierre </li>, antes del </ul> de la lista. Reemplazo acotado
// al primer cierre de la lista legal para no afectar a otras listas del footer.
htmlFooter = htmlFooter.replace(
  /(href="\/es\/politica-de-cookies\/"[\s\S]*?<\/a>\s*<\/li>)/,
  `$1${itemAccesibilidad}`,
);
---

{/* Chrome real del footer (incluye su propio <footer> landmark con role WPFooter). */}
<Fragment set:html={htmlFooter} />
