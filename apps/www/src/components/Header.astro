---
// Header de Caleta Suites — esqueleto AAA.
// Incluye skip link (salto al contenido principal) para accesibilidad de teclado.
// El diseño real (logo, layout) se replicará del tema WordPress en la migración.
import Navbar from './Navbar.astro';
interface Props {
  /** Idioma activo: 'en' (raíz) | 'es' (/es/). */
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = lang === 'es' ? '/es/' : '/';
const saltarTexto = lang === 'es' ? 'Saltar al contenido principal' : 'Skip to main content';
---

{/* Skip link: visible solo al recibir foco (estilos en global.css). */}
<a href="#contenido-principal" class="skip-link">{saltarTexto}</a>

<header>
  <a href={base} aria-label={lang === 'es' ? 'Caleta Suites Tenerife — inicio' : 'Caleta Suites Tenerife — home'}>
    {/* TODO F-Migra: sustituir por el logo real del tema WordPress. */}
    <span>Caleta Suites Tenerife</span>
  </a>
  <Navbar lang={lang} />
</header>
