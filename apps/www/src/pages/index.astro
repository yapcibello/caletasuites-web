---
// Home EN (path "/") de la migracion WP -> Astro.
//
// REGLA INNEGOCIABLE: path inmutable "/". La home se sirve aqui (y no desde el
// catch-all [...ruta].astro, que la excluye) para evitar colision de rutas.
// Renderiza el HTML crudo migrado de la home, no un placeholder.
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// HTML crudo de Elementor (uploads ya reescritos). Mismo patron que el catch-all.
const htmlPorRuta = import.meta.glob('../content/_raw/**/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const htmlPorRawKey: Record<string, string> = {};
for (const [ruta, html] of Object.entries(htmlPorRuta)) {
  const rawKey = ruta.split('/').pop()!.replace(/\.html$/, '');
  htmlPorRawKey[rawKey] = html as string;
}

// Localiza la entrada de la home EN por su path inmutable "/".
const paginas = await getCollection('paginas');
const home = paginas.find((p) => p.data.path === '/');
if (!home) {
  throw new Error('No se encontro la entrada de la home (path "/") en la coleccion paginas.');
}

const html = htmlPorRawKey[home.data.rawKey];
if (html === undefined) {
  throw new Error(`No se encontro el HTML crudo para la home (rawKey="${home.data.rawKey}").`);
}
---

<Layout
  title={home.data.seoTitle ?? home.data.title}
  description={home.data.seoDescription ?? home.data.descripcion}
  lang={home.data.idioma}
  ogImage={home.data.ogImage}
  altPath={home.data.altPath}
>
  {/* Inyeccion del HTML migrado de la home (incluye iframes Icnea si los hubiera). */}
  <div set:html={html} />
</Layout>
