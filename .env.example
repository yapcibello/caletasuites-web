# Variables de entorno del monorepo caletasuites-web.
# Copia este archivo a .env y rellena los valores reales.
# El .env real está en .gitignore — NUNCA subas credenciales al repositorio.
#
# NOTA: este .env (raíz) es para los scripts de deploy.
# Las variables de medición (GTM, GA4) van en apps/www/.env (Vite/Astro
# no lee el .env del raíz del monorepo en tiempo de build).

# --- Deploy a Hestia via FTP — usado por scripts/deploy-ftp.sh ---
# Servidor FTP de Hestia (normalmente el mismo host que el dominio).
# Obtener en el panel Hestia: Web → caletasuitestenerife.com → FTP Accounts.
FTP_HOST=

# Usuario FTP creado en el panel Hestia para el dominio.
FTP_USER=

# Contraseña FTP (se recomienda generar una específica en Hestia, no reutilizar la del panel).
FTP_PASS=

# Ruta absoluta del document root en la jaula FTP de Hestia.
# Convención Hestia: /home/<usuario>/web/caletasuitestenerife.com/public_html/
# (con slash final — el script lo usa como prefijo de ruta directamente).
FTP_REMOTE_DIR=/home/<usuario>/web/caletasuitestenerife.com/public_html/

# URL base pública del site (se usa para el smoke test post-deploy).
DEPLOY_BASE_URL=https://caletasuitestenerife.com
