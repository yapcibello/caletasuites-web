# Variables de DEPLOY del monorepo (raíz). Copia este archivo a .env y rellena
# los valores reales. El .env real está en .gitignore — NUNCA subas credenciales.
#
# NOTA: este .env (raíz) es para los scripts de deploy. El .env de medición (GTM)
# vive aparte en apps/www/.env (Astro/Vite no lee el .env del raíz del monorepo).

# --- Deploy a Hestia VPS (rsync+SSH) — usado por scripts/deploy-www.sh ---
# Alias SSH (definido en ~/.ssh/config) o user@host del VPS Hestia.
# TODO: pendiente del usuario — el host de Caleta Suites aún no está confirmado.
WWW_SSH_HOST=

# Ruta absoluta del document root en el servidor (convención Hestia:
# /home/<user>/web/<dominio>/public_html).
# TODO: pendiente del usuario — el directorio remoto aún no está confirmado.
WWW_REMOTE_DIR=

# (Opcional) URL pública para el smoke test post-deploy. Si se omite, el deploy
# se completa pero NO ejecuta el smoke test HTTP.
# TODO: confirmar dominio definitivo en producción.
WWW_SMOKE_URL=
