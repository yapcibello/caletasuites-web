{
  "name": "caletasuites-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:www": "pnpm --filter @caletasuites/www dev",
    "build:www": "pnpm --filter @caletasuites/www build",
    "deploy:www": "bash scripts/deploy-ftp.sh",
    "deploy:ftp-check": "bash scripts/ftp-check.sh",
    "verify:html-diff": "bash scripts/verify-no-html-diff.sh",
    "verify:sitemap-images": "node scripts/verify-sitemap-images.mjs",
    "test": "vitest run",
    "hero:list": "node scripts/list-hero-photos.mjs"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
